class Solution {
    public int maxNumberOfBalloons(String text) {
        int[] f = new int[26];
        for (char ch: text.toCharArray()) {
            f[ch - 'a']++;
        }
        int b = f['b' - 'a'];
        int a = f['a' - 'a'];
        int l = f['l' - 'a'] / 2;
        int o = f['o' - 'a'] / 2;
        int n = f['n' - 'a'];
        return Math.min(b,
               Math.min(a,
               Math.min(l,
               Math.min(o, n))));
    }
}
