class Solution {
    public int[] smallerNumbersThanCurrent(int[] nums) {
        int[] c = new int[102];
        for (int n : nums) {
            c[n + 1]++;
        }
        for (int i = 1; i < c.length; i++) {
            c[i] += c[i - 1];
        }
        int[] res = new int[nums.length];
        for (int i = 0; i < nums.length; i++) {
            res[i] = c[nums[i]];
        }
        return res;
    }
}
