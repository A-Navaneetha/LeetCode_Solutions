class Solution {
    public int findNumbers(int[] nums) {
        int c = 0;
        for (int n : nums) {
            int dig = 0;
            while (n > 0) {
                dig++;
                n /= 10;
            }
            if (dig % 2 == 0) {
                c++;
            }
        }
        return c;
    }
}
