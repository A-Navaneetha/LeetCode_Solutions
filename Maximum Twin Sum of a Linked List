class Solution {
    public int pairSum(ListNode head) {
        ListNode slow = head;
        ListNode fast = head;
        while (fast != null && fast.next != null) {
            slow = slow.next;
            fast = fast.next.next;
        }
        ListNode prev = null;
        while (slow != null) {
            ListNode next = slow.next;
            slow.next = prev;
            prev = slow;
            slow = next;
        }
        int Sum = 0;
        ListNode f= head;
        ListNode s = prev;
        while (s != null) {
            Sum = Math.max(Sum, f.val + s.val);
            f = f.next;
            s = s.next;
        }
        return Sum;
    }
}
