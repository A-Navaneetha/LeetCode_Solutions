class Solution {
    public int maxIceCream(int[] costs, int coins) {
        int[] freq = new int[100001];
        for (int c : costs) {
            freq[c]++;
        }
        int ans = 0;
        for (int c = 1; c <= 100000; c++) {
            while (freq[c] > 0 && coins >= c) {
                coins -= c;
                ans++;
                freq[c]--;
            }
        }
        return ans;
    }
}
