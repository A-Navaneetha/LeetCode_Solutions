class Solution {
    public int binaryGap(int n) {
        int pre = -1;
        int max = 0;
        int pos= 0;
        while (n > 0) {
            if ((n & 1) == 1) {
                if (pre != -1) {
                    max = Math.max(max, pos - pre);
                }
                pre = pos;
            }
            pos++;
            n >>= 1;
        }
        return max;
    }
}
