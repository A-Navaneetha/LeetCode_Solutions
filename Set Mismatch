class Solution {
    public int[] findErrorNums(int[] nums) {
        int n = nums.length;
        int[] fre = new int[n + 1];
        for (int j : nums) {
            fre[j]++;
        }
        int d= 0;
        int missing = 0;
        for (int i = 1; i <= n; i++) {
            if (fre[i] == 2) {
                d = i;
            } else if (fre[i] == 0) {
                missing = i;
            }
        }
        return new int[]{d, missing};
    }
}
