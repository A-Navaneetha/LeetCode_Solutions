class Solution {
    TreeNode h = new TreeNode(0);
    TreeNode cur = h;
    public TreeNode increasingBST(TreeNode root) {
        inorder(root);
        return h.right;
    }
    private void inorder(TreeNode node) {
        if (node == null) {
            return;
        }
        inorder(node.left);
        node.left = null;
        cur.right = node;
        cur = node;
        inorder(node.right);
    }
}
