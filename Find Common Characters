class Solution:
    def commonChars(self, words: List[str]) -> List[str]:
        fre = [float('inf')] * 26

        for word in words:
            c = [0] * 26

            for ch in word:
                c[ord(ch) - ord('a')] += 1

            for i in range(26):
                fre[i] = min(fre[i], c[i])

        ans = []

        for i in range(26):
            ans.extend([chr(i + ord('a'))] * fre[i])

        return ans
