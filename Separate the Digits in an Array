class Solution {
    public int[] separateDigits(int[] nums) {
        List<Integer> l = new ArrayList<>();
        for (int n : nums) {
            String s = String.valueOf(n);
            for (char c : s.toCharArray()) {
                l.add(c - '0');
            }
        }
        int[] ans = new int[l.size()];
        for (int i = 0; i < l.size(); i++) {
            ans[i] = l.get(i);
        }
        return ans;
    }
}
